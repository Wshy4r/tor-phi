{
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "generate:congress": "node scripts/generate-us-congress.mjs",
    "generate:congress-social": "node scripts/generate-us-congress-social.mjs",
    "import:congress-books": "node scripts/import-congressional-books.mjs",
    "import:us-congress-official": "node scripts/import-us-congress-official.mjs",
    "generate:turkiye-parliament": "node scripts/generate-turkish-parliament.mjs",
    "generate:france-parliament": "node scripts/generate-france-parliament.mjs",
    "generate:uk-parliament": "node scripts/generate-uk-parliament.mjs",
    "generate:iran-parliament": "node scripts/generate-iran-parliament.mjs",
    "import:parliament-sessions": "node scripts/import-parliament-sessions.mjs",
    "import:foreign-ministry-sources": "node scripts/import-foreign-ministry-sources.mjs",
    "import:landau-remarks": "node scripts/import-landau-state-remarks.mjs",
    "watch:parliament-sessions": "node scripts/watch-parliament-sessions.mjs",
    "watch:parliament-sessions:deep": "PARLIAMENT_SESSION_REFRESH_SOURCES=1 node scripts/watch-parliament-sessions.mjs",
    "import:tbmm-speeches": "node scripts/import-tbmm-speech-details.mjs",
    "translate:tbmm-speeches": "node scripts/translate-tbmm-speeches.mjs",
    "translate:tbmm-speech-metadata": "node scripts/translate-tbmm-speech-metadata.mjs",
    "translate:tbmm-record-metadata": "node scripts/translate-tbmm-record-metadata.mjs",
    "translate:tbmm-biographies": "node scripts/translate-tbmm-biographies.mjs",
    "build:tbmm-kurdistan-briefs": "node scripts/build-tbmm-kurdistan-briefs.mjs",
    "sync:social-accounts": "node scripts/sync-social-accounts.mjs",
    "discover:x-accounts": "node scripts/discover-x-accounts.mjs",
    "discover:x-accounts:priority": "node scripts/discover-x-accounts.mjs --owner-type \"Country profile actor\" --owner-type \"Foreign ministry\" --owner-type Congress --owner-type \"Think tank\" --owner-type Media --limit 180",
    "capture:social": "python3 scripts/torphi-social-capture.py",
    "capture:parliament": "python3 scripts/torphi-social-capture.py --owner-type Congress --owner-type Parliament",
    "capture:parliament:usa": "python3 scripts/torphi-social-capture.py --country usa --owner-type Congress",
    "capture:parliament:france": "python3 scripts/torphi-social-capture.py --country france --owner-type Parliament",
    "capture:parliament:uk": "python3 scripts/torphi-social-capture.py --country uk --owner-type Parliament",
    "capture:parliament:turkey": "python3 scripts/torphi-social-capture.py --country turkey --owner-type Parliament",
    "capture:parliament:iran": "python3 scripts/torphi-social-capture.py --country iran --owner-type Parliament",
    "capture:social:kurdistan": "python3 scripts/torphi-social-capture.py --lane kurdistan --limit 25",
    "capture:social:iraq": "python3 scripts/torphi-social-capture.py --lane iraq --limit 25",
    "capture:social:deep": "python3 scripts/torphi-social-capture.py --all --pages 8 --include-replies --pause 3.5",
    "capture:social:kurdistan-deep": "python3 scripts/torphi-social-capture.py --lane kurdistan --all --pages 8 --pause 3",
    "capture:social:iraq-deep": "python3 scripts/torphi-social-capture.py --lane iraq --all --pages 8 --pause 3",
    "archive:social:deep": "npm run sync:social-accounts && npm run capture:social:kurdistan-deep && npm run capture:social:iraq-deep && npm run import:social-snapshot",
    "import:social-snapshot": "node scripts/sync-social-accounts.mjs && python3 scripts/export-social-snapshot.py",
    "export:social-archive": "python3 scripts/export-social-archive-jsonl.py",
    "import:social-archive": "python3 scripts/import-social-archive-jsonl.py",
    "sync:github-social": "node scripts/sync-github-social-archive.mjs",
    "social:control": "node scripts/social-control-server.mjs",
    "github:status": "node scripts/github-status-server.mjs",
    "social:analyzer": "bash \"Social Analyzer/run-local.sh\"",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest",
    "yaml": "^2.9.0"
  }
}
