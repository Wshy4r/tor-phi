{
  "manifest_version": 3,
  "name": "Twitter Analyzer - Tweet Capture",
  "version": "1.0.0",
  "description": "Automatically captures tweets from Twitter/X and sends them to a local backend for storage and analysis.",
  "permissions": [
    "storage",
    "cookies",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twitter Analyzer"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://twitter.com/*", "https://x.com/*"]
    }
  ],
  "icons": {}
}
