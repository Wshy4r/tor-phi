{"captured_at": "2026-07-17T13:17:09.453711Z", "created_at": "Sat Apr 01 08:33:45 +0000 2023", "created_at_iso": "2023-04-01T08:33:45Z", "created_at_ts": 1680338025, "display_name": "Isabel Coles", "handle": "isabelcoles", "id": "1642082812822994946", "language": "en", "media_json": "[]", "metrics_json": "{\"retweet_count\": 9, \"reply_count\": 0, \"like_count\": 18, \"quote_count\": 0, \"bookmark_count\": 0, \"view_count\": null}", "source_endpoint": "SyndicationProfile", "tags_json": "[]", "text": "In just one year working for @WSJ our colleague @evangershkovich has done such great work. Read it here &amp; join us in calling on #Russia to release him https://t.co/xzTjgMeRSU #IStandwithEvan", "tweet_type": "tweet", "urls_json": "[{\"url\": \"https://t.co/xzTjgMeRSU\", \"expanded_url\": \"https://www.wsj.com/story/on-the-ground-in-putins-russia-evan-gershkovichs-coverage-of-a-country-at-war-922125c2\", \"display_url\": \"wsj.com/story/on-the-g…\"}]", "username": "IsabelColes"}
