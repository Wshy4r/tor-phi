{"captured_at": "2026-07-17T12:17:56.510235Z", "created_at": "Thu Jun 30 18:24:12 +0000 2022", "created_at_iso": "2022-06-30T18:24:12Z", "created_at_ts": 1656613452, "display_name": "Chuck Edwards", "handle": "chuckedwards4nc", "id": "1542574740782694400", "language": "en", "media_json": "[{\"type\": \"photo\", \"url\": \"https://pbs.twimg.com/media/FWhTjDOWYAEixq4.jpg\", \"alt_text\": null}, {\"type\": \"photo\", \"url\": \"https://pbs.twimg.com/media/FWhTjDXXEAIXwI8.jpg\", \"alt_text\": null}]", "metrics_json": "{\"retweet_count\": 1, \"reply_count\": 5, \"like_count\": 23, \"quote_count\": 2, \"bookmark_count\": 0, \"view_count\": null}", "source_endpoint": "SyndicationProfile", "tags_json": "[]", "text": "It’s Melon Day at the Capitol! Every year @SenBrentJackson brings a trailer full of his NC grown melons for everyone to enjoy.\n\nI can never pass on the chance to eat delicious local produce so I got a melon. Small farmers like Brent are why I will always support NC’s Ag industry! https://t.co/fEKzA1paiv", "tweet_type": "tweet", "urls_json": "[]", "username": "ChuckEdwards4NC"}
